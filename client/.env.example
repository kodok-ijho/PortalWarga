# Aktifkan mode demo (preview UI tanpa Supabase). Set "false" saat Supabase siap.
VITE_DEMO_MODE=true

# Kredensial Supabase — dapatkan dari dashboard Supabase Anda:
# Project Settings > API > Project URL & anon public key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
