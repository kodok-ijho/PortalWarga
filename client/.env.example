# Environment aplikasi: local, staging, atau production.
VITE_APP_ENV=local

# Aktifkan mode demo (preview UI tanpa backend production).
# Gunakan "false" untuk staging/production.
VITE_DEMO_MODE=true

# API backend n8n. Dibutuhkan saat VITE_DEMO_MODE=false.
VITE_N8N_API_BASE_URL=https://api.example.com/webhook/portal-v1

# Google OAuth Web Client ID. Public-safe untuk frontend.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Kredensial Supabase public. Dapatkan dari dashboard Supabase:
# Project Settings > API > Project URL dan anon public key.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
